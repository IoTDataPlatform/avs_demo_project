{
  "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
  "tasks.max": "1",
  "topics": "avs-source",
  "connection.url": "jdbc:postgresql://timescaledb:5432/avs",
  "connection.user": "user",
  "connection.password": "password",
  "table.name.format": "sensor_readings",
  "auto.create": "false",
  "auto.evolve": "false",
  "insert.mode": "upsert",
  "pk.mode": "record_value",
  "pk.fields": "sensor_id,ts",
  "quote.sql.identifiers": "always",
  "key.converter": "org.apache.kafka.connect.storage.StringConverter",
  "value.converter": "io.confluent.connect.avro.AvroConverter",
  "value.converter.schema.registry.url": "http://kafka-schema-registry:8081",
  "transforms": "RenameFields",
  "transforms.RenameFields.type": "org.apache.kafka.connect.transforms.ReplaceField$Value",
  "transforms.RenameFields.renames": "sensorId:sensor_id,buildingName:building_name,roomNumber:room_number"
}